# ────────────────────────────────────────────────────────────────
# OreoEssentials Web Panel — environment variables
# Copy this file to .env (never commit .env!) and fill in values.
# ────────────────────────────────────────────────────────────────

# ─── Central PostgreSQL ─────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/oreoessentials_web
DB_USERNAME=oreo
DB_PASSWORD=CHANGE_ME

# ─── JWT ────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with:
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_SECRET_KEY_HERE

# ─── AES-256-GCM encryption key for MongoDB URIs ────────────────
# Must be EXACTLY 32 ASCII characters (256 bits). Generate with:
#   openssl rand -base64 24 | tr -d '=' | cut -c1-32
ENCRYPTION_KEY=CHANGE_ME_EXACTLY_32_BYTES_HERE!!

# ─── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://your-frontend.example.com

# ─── Server port ────────────────────────────────────────────────
PORT=8080

# ─── Spring profile ─────────────────────────────────────────────
# Set to 'prod' in production
SPRING_PROFILES_ACTIVE=dev
